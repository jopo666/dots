### VARIABLES ###
set $alt mod1
set $super mod4
set $open $HOME/.config/i3/open-if-not-running
set $ws_files files
set $ws_web web
set $ws_term term
set $ws_code code
set $ws_docker docker
set $ws_mail mail
set $ws_slack slack

### STARTUP ###
exec_always --no-startup-id $HOME/.config/i3/autolayout autolayout &
exec --no-startup-id unclutter -idle 1 &

### GENERAL ###
floating_modifier $alt
focus_follows_mouse no
font pango:BigBlueTermPlus Nerd Font 9
new_window pixel 2
smart_borders on
workspace_auto_back_and_forth yes

### KEYBINDS ###
bindsym $alt+q kill
bindsym $alt+w workspace $ws_web; exec $open -w $ws_web -p instance -v chromium -c chromium
bindsym $alt+e workspace $ws_term; exec $open -w $ws_term -p instance -v alacritty -c alacritty
# r
bindsym $alt+t floating toggle
bindsym $alt+y workspace $ws_code; exec $open -w $ws_code -p instance -v codium -c codium
bindsym $alt+u resize shrink width 5 px or 5 ppt
bindsym $alt+i resize grow width 5 px or 5 ppt
bindsym $alt+o exec "dmenu_run -b -nf '#555555' -nb '#000000' -sb '#000000' -sf '#EEEEEE' -fn 'BigBlueTermPlus Nerd Font-10'  -p '>>'"
bindsym $alt+p [class="files"] scratchpad show; move position center;
bindsym $alt+s workspace $ws_slack; exec $open -w $ws_slack -p instance -v slack -c slack
bindsym $alt+d workspace $ws_docker; exec $open -w $ws_docker -p instance -v slack -c alacritty --class "docker" -e lazydocker
# d
bindsym $alt+f fullscreen
# g
bindsym $alt+h focus left
bindsym $alt+j focus down
bindsym $alt+k focus up
bindsym $alt+l focus right
# z
bindsym $alt+c [class="python"] scratchpad show; move position center;
# x
# c
# v
# b
# n
bindsym $alt+m workspace $ws_mail; exec $open -w $ws_mail -p name -v Inbox -c chromium-browser https://mail.google.com/mail/u/1/#inbox --new-window
# Shift
bindsym $alt+Shift+w [class="wifi"] scratchpad show; move position center
bindsym $alt+Shift+r restart
bindsym $alt+Shift+s [class="audio"] scratchpad show; move position center;
bindsym $alt+Ctrl+h move left
bindsym $alt+Ctrl+j move down
bindsym $alt+Ctrl+k move up
bindsym $alt+Ctrl+l move right
bindsym $alt+1 workspace number 1
bindsym $alt+2 workspace number 2
bindsym $alt+3 workspace number 3
bindsym $alt+4 workspace number 4
bindsym $alt+5 workspace number 5
bindsym $alt+6 workspace number 6
bindsym $alt+7 workspace number 7
bindsym $alt+8 workspace number 8
bindsym $alt+9 workspace number 9
bindsym $alt+Shift+1 move container to workspace number 1
bindsym $alt+Shift+2 move container to workspace number 2
bindsym $alt+Shift+3 move container to workspace number 3
bindsym $alt+Shift+4 move container to workspace number 4
bindsym $alt+Shift+5 move container to workspace number 5
bindsym $alt+Shift+6 move container to workspace number 6
bindsym $alt+Shift+7 move container to workspace number 7
bindsym $alt+Shift+8 move container to workspace number 8
bindsym $alt+Shift+9 move container to workspace number 9
# xf86
bindsym XF86MonBrightnessUp exec brightnessctl s 20%+
bindsym XF86MonBrightnessDown exec brightnessctl s 20%-
bindsym XF86AudioRaiseVolume exec --no-startup-id pulsemixer --change-volume +25
bindsym XF86AudioLowerVolume exec --no-startup-id pulsemixer --change-volume -25
bindsym XF86AudioMute exec --no-startup-id pulsemixer --toggle-mute
# special
bindsym $alt+BackSpace mode "$powermenu"
bindsym $alt+Return exec alacritty
bindsym $super+Return exec chromium
# cut/copy/paste with super
bindsym --release $super+c exec --no-startup-id xdotool key --clearmodifiers Ctrl+Insert
bindsym --release $super+x exec --no-startup-id xdotool key --clearmodifiers Shift+Delete
bindsym --release $super+v exec --no-startup-id xdotool key --clearmodifiers Shift+Insert

### ASSIGNMENTS ###
assign [class="chromium"] $ws_web
assign [class="alacritty"] $ws_term
assign [class="slack"] $ws_slack
assign [class="codium"] $ws_code
assign [class="docker"] $ws_docker
assign [class="mail"] $ws_mail

### SCRATCHPADS ###
exec_always $open -p class -v wifi -c alacritty --class "wifi" -e nmtui
for_window [class="wifi"] floating enable
for_window [class="wifi"] move scratchpad
exec_always $open -p class -v audio -c alacritty --class "audio" -e pulsemixer
for_window [class="audio"] floating enable
for_window [class="audio"] resize set 600 300
for_window [class="audio"] move scratchpad
exec_always $open -p class -v python -c alacritty --class "python" -e python3
for_window [class="python"] floating enable
for_window [class="python"] move scratchpad
exec_always $open -p class -v files -c alacritty --class "files" -e lf
for_window [class="files"] floating enable
for_window [class="files"] move scratchpad

### MODES ###
set $screenlock i3lock -c 282828 -u
set $powermenu SYSTEM >> (L)OCK (H)IBERNATE (R)EBOOT (S)HUTDOWN
mode "$powermenu" {
    bindsym e exec --no-startup-id i3-msg exit, mode "default"
    bindsym l exec --no-startup-id $screenlock, mode "default"
    bindsym h exec --no-startup-id $screenlock && systemctl hibernate, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym s exec --no-startup-id systemctl poweroff -i, mode "default"
    bindsym Return mode "default"
    bindsym BackSpace mode "default"
    bindsym Escape mode "default"
}

