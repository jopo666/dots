### VARIABLES ###
set $alt mod1
set $super mod4
set $open exec $HOME/.config/i3/open-if-not-running

### STARTUP ###
exec_always --no-startup-id $HOME/.config/i3/autolayout autolayout &
exec --no-startup-id unclutter -idle 1 &
exec --no-startup-id dunst
exec --no-startup-id chromium

### GENERAL ###
floating_modifier $alt
focus_follows_mouse no
font pango:BigBlueTermPlus Nerd Font 12
new_window pixel 6
smart_borders on
workspace_auto_back_and_forth no

### KEYBINDS ###
bindsym $alt+Return exec alacritty
bindsym $super+Return exec chromium
bindsym $alt+q kill
bindsym $alt+w workspace web;
bindsym $alt+e workspace tty; $open -w tty -s scratch
bindsym $alt+r restart
bindsym $alt+t fullscreen toggle
bindsym $alt+shift+t floating toggle
bindsym $alt+y exec --no-startup-id  flameshot gui -s -c -p $HOME/captures/
bindsym $alt+shift+y exec --no-startup-id  flameshot screen -c -p $HOME/captures/
# y
bindsym $alt+u resize shrink width 5 px or 5 ppt
bindsym $alt+i resize grow width 5 px or 5 ppt
bindsym $alt+o exec "dmenu_run -nf '#FFFFFF' -nb '#000000' -sb '#FFFFFF' -sf '#000000' -fn 'BigBlueTermPlus Nerd Font-11' -p ''"
bindsym $alt+p workspace prev
bindsym $alt+a workspace llm; $open -w llm -s llm
# bindsym $alt+s workspace slack; $open -w slack -s slack
# bindsym $alt+d workspace docker; $open -w docker -s docker lazydocker
bindsym $alt+f workspace files; $open -w files -s files lf
# g
bindsym $alt+h focus left
bindsym $alt+Ctrl+h move left
bindsym $alt+j focus down
bindsym $alt+Ctrl+j move down
bindsym $alt+k focus up
bindsym $alt+Ctrl+k move up
bindsym $alt+l focus right
bindsym $alt+Ctrl+l move right
#bindsym $alt+z workspace zoom; $open -w zoom -k name -v Zoom chromium zoom.us
#bindsym --release $super+c exec --no-startup-id xdotool key --clearmodifiers Ctrl+Insert
#bindsym --release $super+x exec --no-startup-id xdotool key --clearmodifiers Shift+Delete
#bindsym --release $super+v exec --no-startup-id xdotool key --clearmodifiers Shift+Insert
bindsym $alt+b workspace back_and_forth
bindsym $alt+n workspace next
bindsym $alt+m workspace mail; $open -w mail -s mail neomutt
# Shift
bindsym $alt+1 workspace number 1
bindsym $alt+2 workspace number 2
bindsym $alt+3 workspace number 3
bindsym $alt+4 workspace number 4
bindsym $alt+5 workspace number 5
bindsym $alt+6 workspace number 6
bindsym $alt+7 workspace number 7
bindsym $alt+8 workspace number 8
bindsym $alt+9 workspace number 9
bindsym $alt+Shift+1 move container to workspace number 1
bindsym $alt+Shift+2 move container to workspace number 2
bindsym $alt+Shift+3 move container to workspace number 3
bindsym $alt+Shift+4 move container to workspace number 4
bindsym $alt+Shift+5 move container to workspace number 5
bindsym $alt+Shift+6 move container to workspace number 6
bindsym $alt+Shift+7 move container to workspace number 7
bindsym $alt+Shift+8 move container to workspace number 8
bindsym $alt+Shift+9 move container to workspace number 9
# special
bindsym XF86MonBrightnessUp exec brightnessctl s 20%+
bindsym XF86MonBrightnessDown exec brightnessctl s 20%-
bindsym XF86AudioRaiseVolume exec --no-startup-id pulsemixer --change-volume +25
bindsym XF86AudioLowerVolume exec --no-startup-id pulsemixer --change-volume -25
bindsym XF86AudioMute exec --no-startup-id pulsemixer --toggle-mute
bindsym XF86AudioMicMute exec --no-startup-id amixer set Capture toggle

### MODES ###
bindsym $alt+BackSpace mode "$powermenu"
set $powermenu SYSTEM >> (L)OCK (H)IBERNATE (R)EBOOT (S)HUTDOWN
set $screenlock i3lock -u -i $HOME/.config/i3/lockscreen.png
mode "$powermenu" {
    bindsym e exec --no-startup-id i3-msg exit, mode "default"
    bindsym l exec --no-startup-id $screenlock, mode "default"
    bindsym h exec --no-startup-id $screenlock && systemctl hibernate, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym s exec --no-startup-id systemctl poweroff -i, mode "default"
    bindsym Return mode "default"
    bindsym BackSpace mode "default"
    bindsym Escape mode "default"
}


### COLORS ###
#                       border  bground text    indicator child_border
client.focused          #000000 #000000 #FFFFFF #FFFFFF   #FFFFFF
client.focused_inactive #000000 #000000 #FFFFFF #000000   #000000
client.unfocused        #000000 #000000 #FFFFFF #000000   #000000
client.urgent           #000000 #000000 #FFFFFF #000000   #000000
client.placeholder      #000000 #000000 #FFFFFF #000000   #000000
client.background       #FFFFFF

bar {
  status_command i3status
  mode dock
  hidden_state hide
  modifier $alt
  colors {
    background #000000
    statusline #FFFFFF
    separator  #333333
    focused_workspace  #FFFFFF #000000 #FFFFFF
    active_workspace   #000000 #000000 #FFFFFF
    inactive_workspace #000000 #000000 #FFFFFF
    urgent_workspace   #000000 #000000 #FFFFFF
    binding_mode       #000000 #000000 #FF0000
  }
}
