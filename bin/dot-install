#!/bin/sh

set -euo pipefail

USAGE="Usage: $0 [-f input-file] [package]"
PACKAGE=""; INPUT_FILE="";
INSTALLED=""; 

while [[ $# -gt 0 ]]; do
  case $1 in
    -f) INPUT_FILE="$2"; shift 2; ;;
    -h|--help) echo $USAGE; exit 1; ;;
    -*|--*) echo $USAGE; echo "Unknown option $1."; exit 1; ;;
    *) PACKAGE=$1; shift 1; ;;
  esac
done

if [ -z "$PACKAGE" ] && [ -z "$INPUT_FILE" ]; then
  echo $USAGE; echo "Provide either input file or package name.";
  exit 1
fi

install() {
  local name=$1
  if [ -z "$INSTALLED" ]; then
    INSTALLED=$(nix profile list | while IFS= read -r line; do
      echo "$line" | awk '{print $2}' | cut -d. -f3-
    done)
  fi
  if echo "$INSTALLED" | grep -q "$name"; then
    echo "$name is already installed!"
  else
    echo "Installing $name..."
    nix profile install "nixpkgs#$name"
  fi
}

if [ ! -z "$PACKAGE" ]; then
  install $PACKAGE
else
  while IFS= read -r line; do
    if [[ -n "$line" && "$line" != \#* ]]; then
      package=$(echo "$line" | awk '{print $1}')
      install $package
    fi
  done < "$INPUT_FILE"
fi

